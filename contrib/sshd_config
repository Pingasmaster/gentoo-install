Protocol 2                                                     # Protocol 1 is removed in modern OpenSSH
AuthorizedKeysFile .ssh/authorized_keys                        # Load authorized keys from user's home
#ListenAddress [ip-here]
#Port 22

AuthenticationMethods publickey                                # Only public key authentication allowed
HostKey /etc/ssh/ssh_host_ed25519_key                          # Use only the Ed25519 host key
HostKeyAlgorithms ssh-ed25519                                  # Server offers only Ed25519 host key signature
KexAlgorithms mlkem768x25519-sha256                            # Post-quantum hybrid (OpenSSH 10.x default)
Ciphers chacha20-poly1305@openssh.com                          # AEAD cipher; OpenSSH prefers this first
MACs hmac-sha2-512-etm@openssh.com                             # Encrypt-then-MAC with SHA-512
# Only accept Ed25519 signatures from clients:
HostbasedAcceptedAlgorithms ssh-ed25519
PubkeyAcceptedAlgorithms ssh-ed25519

PermitRootLogin no
AllowUsers user
MaxAuthTries 2
PermitUserRC no
PasswordAuthentication no
KbdInteractiveAuthentication no

DisableForwarding yes                                          # Disables X11, agent, TCP, StreamLocal (fixed in 10.0)
#AllowTcpForwarding no
#AllowStreamLocalForwarding no
#AllowAgentForwarding no
#X11 forwarding disabled by default

#Banner /etc/ssh/sshd-banner
PrintMotd no
ClientAliveInterval 100
LoginGraceTime 10
#AcceptEnv LANG LC_*
Subsystem sftp /usr/lib64/misc/sftp-server
